{
  "manifest_version": 3,
  "name": "Linkosh",
  "version": "0.1.0",
  "description": "Fetch and list your saved items from LinkedIn, Instagram, YouTube, Hacker News, X, Facebook and Substack (more services coming).",
  "permissions": ["storage", "cookies", "offscreen", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.instagram.com/*",
    "https://www.youtube.com/*",
    "https://news.ycombinator.com/*",
    "https://x.com/*",
    "https://www.facebook.com/*",
    "https://substack.com/*"
  ],
  "optional_host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.voyageai.com/*",
    "https://api.anthropic.com/*"
  ],
  "options_ui": {
    "page": "pages/options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    { "resources": ["debug.html"], "matches": ["<all_urls>"] }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "ext/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "pages/popup/popup.html",
    "default_title": "Linkosh"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
